{
    "name": "Smart IoT Farming Kit",
    "version": 2,
    "buildCommand": "pip install -r requirements.txt",
    "builds": [
      {
        "src": "api/index.py",
        "use": "@vercel/python@2.1.2"
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "api/index.py"
      }
    ],
    "env": {
      "PYTHONPATH": "/var/task"
    }
  }